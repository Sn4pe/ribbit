---
interface Props {
	currentPath: string;
}

const { currentPath } = Astro.props;
const links = [
	{ href: "/#grid", label: "Grid" },
	{ href: "/#playground", label: "Playground" },
	{ href: "/docs", label: "Docs" },
];
---

<header class="sticky top-0 z-50 border-b border-line/80 bg-bg/80 backdrop-blur-md">
	<div class="mx-auto flex h-16 max-w-6xl items-center justify-between px-5 lg:px-8">
		<a class="mono flex items-baseline text-lg font-medium tracking-tight text-fg" href="/" aria-label="ribbit home">
			<span>ribbit</span><span class="ml-1 inline-block h-[0.95em] w-[0.5ch] translate-y-[0.08em] bg-brand" aria-hidden="true"></span>
		</a>

		<nav class="mono hidden items-center gap-8 text-sm md:flex" aria-label="Primary">
			{
				links.map((link) => (
					<a
						class:list={[
							"text-muted transition-colors hover:text-fg",
							{ "text-fg": currentPath === link.href || (link.href === "/docs" && currentPath.startsWith("/docs")) },
						]}
						href={link.href}
					>
						{link.label}
					</a>
				))
			}
			<a class="text-muted transition-colors hover:text-fg" href="https://github.com/null-frog/ribbit" aria-label="ribbit on GitHub">
				<svg viewBox="0 0 16 16" width="18" height="18" fill="currentColor" aria-hidden="true"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0016 8c0-4.42-3.58-8-8-8z"/></svg>
			</a>
		</nav>

		<button
			type="button"
			class="mono grid size-9 place-items-center rounded-card border border-line-strong bg-surface text-fg md:hidden"
			aria-expanded="false"
			aria-controls="mobile-navigation"
			aria-label="Open navigation"
			data-menu-toggle
		>
			<span aria-hidden="true">+</span>
		</button>
	</div>

	<nav id="mobile-navigation" class="mono hidden border-t border-line px-5 py-5 md:hidden" aria-label="Mobile" data-menu>
		<div class="mx-auto flex max-w-6xl flex-col gap-4 text-base">
			{links.map((link) => <a class="text-muted" href={link.href}>{link.label}</a>)}
			<a class="text-muted" href="https://github.com/null-frog/ribbit">GitHub</a>
		</div>
	</nav>
</header>

<script>
	const toggle = document.querySelector<HTMLButtonElement>("[data-menu-toggle]");
	const menu = document.querySelector<HTMLElement>("[data-menu]");

	if (toggle && menu) {
		toggle.addEventListener("click", () => {
			const isOpen = toggle.getAttribute("aria-expanded") === "true";
			toggle.setAttribute("aria-expanded", String(!isOpen));
			toggle.setAttribute("aria-label", isOpen ? "Open navigation" : "Close navigation");
			toggle.querySelector("span")?.replaceChildren(isOpen ? "+" : "x");
			menu.classList.toggle("hidden", isOpen);
		});
	}
</script>
