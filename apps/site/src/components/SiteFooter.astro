---
const year = new Date().getFullYear();
---

<footer id="about" class="relative mt-24 overflow-hidden border-t border-line">
	<div class="mx-auto max-w-6xl px-5 pt-14 lg:px-8">
		<div class="flex flex-col gap-8 sm:flex-row sm:items-start sm:justify-between">
			<div class="max-w-sm">
				<p class="text-fg">Deterministic marks for seeds, avatars and covers.</p>
				<p class="mono mt-3 text-sm text-muted">One string in, the same art out, every time.</p>
			</div>
			<nav class="mono flex flex-col gap-3 text-sm" aria-label="Footer">
				<a class="group inline-flex items-center gap-2 text-muted transition-colors hover:text-fg" href="https://github.com/null-frog/ribbit">
					<svg viewBox="0 0 16 16" width="16" height="16" fill="currentColor" aria-hidden="true"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0016 8c0-4.42-3.58-8-8-8z"/></svg>
					GitHub
				</a>
				<a class="group inline-flex items-center gap-2 text-muted transition-colors hover:text-fg" href="https://www.npmjs.com/package/ribbit">
					<svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor" aria-hidden="true"><path d="M2 2v20h20V2H2zm18 18h-3V6H9v14H4V4h16v16z"/></svg>
					npm
				</a>
				<a class="text-muted transition-colors hover:text-fg" href="/docs">Docs</a>
			</nav>
		</div>

		<div class="mono mt-14 flex flex-wrap items-center justify-between gap-3 border-t border-line pt-6 text-xs text-faint">
			<span>MIT licensed</span>
			<span>Built by Null-Frog &middot; {year}</span>
		</div>
	</div>

	<div aria-hidden="true" class="mt-8 flex justify-center overflow-hidden">
		<span class="mono block translate-y-[0.14em] select-none text-[19vw] font-semibold leading-[0.8] tracking-[-0.03em] text-brand-dim/25 lg:text-[15rem]">ribbit</span>
	</div>
</footer>
