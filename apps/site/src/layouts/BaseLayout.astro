---
import Analytics from "@vercel/analytics/astro";
import SiteFooter from "../components/SiteFooter.astro";
import SiteHeader from "../components/SiteHeader.astro";
import "../styles/global.css";

interface Props {
	title?: string;
	description?: string | undefined;
	structuredData?: Record<string, unknown> | Record<string, unknown>[];
}

const {
	title = "ribbit",
	description = "Deterministic generative avatars, canvas marks, SVG, PNG and WebM from any seed. Zero dependencies and no network requests.",
	structuredData,
} = Astro.props;
const pageTitle =
	title === "ribbit"
		? "ribbit — deterministic avatars and generative art"
		: `${title} | ribbit`;
const canonical = new URL(Astro.url.pathname, Astro.site);
const ogImage = new URL("/og.png", Astro.site);
const schemas = structuredData
	? Array.isArray(structuredData)
		? structuredData
		: [structuredData]
	: [];
---

<!doctype html>
<html lang="en" data-theme="dark">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="canonical" href={canonical} />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<meta name="theme-color" content="#0a0d0b" />
		<meta property="og:type" content="website" />
		<meta property="og:title" content={pageTitle} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={canonical} />
		<meta property="og:image" content={ogImage} />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />
		<meta property="og:image:type" content="image/png" />
		<meta name="twitter:card" content="summary_large_image" />
		{schemas.map((schema) => <script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />)}
		<title>{pageTitle}</title>
		<Analytics />
	</head>
	<body class="min-h-screen antialiased">
		<SiteHeader currentPath={Astro.url.pathname} />
		<main>
			<slot />
		</main>
		<SiteFooter />
	</body>
</html>
